# ============================================================
# Simon — contoh konfigurasi environment
# Salin file ini menjadi `.env` lalu isi nilainya:
#   cp .env.example .env
# Semua provider di bawah punya tier GRATIS (sesuai PRD §10).
# ============================================================

# --- Database (WAJIB) ---------------------------------------
# MySQL connection string untuk Prisma.
# Format: mysql://USER:PASSWORD@HOST:PORT/NAMA_DATABASE
# Lokal (XAMPP/Laragon biasanya tanpa password):
#   mysql://root:@localhost:3306/simon
# Buat database-nya dulu (CREATE DATABASE simon;), lalu jalankan:
#   npm run db:push   (membuat tabel)
#   npm run db:seed   (opsional, isi data contoh)
DATABASE_URL="mysql://root:@localhost:3306/simon"

# --- Auth (WAJIB di production) ------------------------------
# Secret untuk menandatangani JWT sesi login (HS256).
# Buat nilai acak dengan: openssl rand -base64 32
# atau: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="ganti-dengan-string-acak-minimal-32-karakter"

# --- URL aplikasi (untuk tautan di email) --------------------
# Dipakai membangun tautan reset password & verifikasi email.
# Lokal: http://localhost:3000 — Production: https://domainmu.com
APP_URL="http://localhost:3000"

# --- Harga saham: Finnhub (opsional) -------------------------
# Daftar gratis di https://finnhub.io (cukup email, tanpa kartu kredit).
# Dashboard → API Key. Tanpa key ini harga SAHAM tidak ter-update
# (harga kripto tetap jalan via CoinGecko tanpa key).
FINNHUB_API_KEY=""

# --- Berita keuangan: Marketaux (opsional) -------------------
# Daftar gratis di https://www.marketaux.com (tanpa data pembayaran).
# Dashboard → API Token. Tanpa token ini feed berita memakai
# data cache/seed terakhir.
MARKETAUX_API_TOKEN=""

# --- Email: Resend (opsional) --------------------------------
# Untuk reset password & verifikasi email.
# Daftar gratis di https://resend.com (3.000 email/bulan, tanpa kartu kredit).
# Dashboard → API Keys → Create API Key (awalan "re_").
# Tanpa key ini, registrasi & login tetap berfungsi normal —
# fitur reset password via email saja yang tidak aktif.
RESEND_API_KEY=""

# Alamat pengirim email. Untuk uji coba boleh pakai default Resend:
#   onboarding@resend.dev
# Untuk production, verifikasi domainmu di Resend lalu pakai mis. no-reply@domainmu.com
EMAIL_FROM="Simon <onboarding@resend.dev>"
